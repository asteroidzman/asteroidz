misc {
    dpms-wake-retrain 1
    layerrule layer_name:exclusion,noblur:1
    drag-tile-to-tile 1
    icon-theme Papirus-Dark
    xwayland-persistence 1
    syncobj 1
    focus-on-activate 1
    // easter egg: at random intervals an Asteroids-style ship flies across the
    // bar and shoots down a UFO. Set to 0 to disable.
    ufo-easter-egg 1
    allow-tearing 2
    sdr {
        reference-luminance 280
        saturation 1.25
    }
}
pill {
    border-width 0
    corner-radius 8
    font "Ubuntu 18"
    padding {
        x 16
        y 4
    }
}
layout {
    monocle {
        tab-max-width 380
    }
    titlebar {
        enable 1
        height 36
    }
    scroller {
        structs 20
        default-proportion 0.48
        focus-center 0
        prefer-center 0
        default-proportion-single 1.0
        preset 0.5,0.8,1.0
        edge-scroll {
            pointer-focus 1
            allow-speed 40
            enable 1
            size 15
            delay 500
        }
    }
}
overview {
    tab-mode 0
    hotarea {
        size 10
        enable 1
    }
    gaps {
        inner 5
        outer 30
    }
}
animations {
    curve spring
    spring {
        damping 0.8
        frequency 22
    }
    window-open {
        type fade
        duration 450
        fade-begin-opacity 0.0
    }
    window-close {
        type fade
        duration 375
        fade-begin-opacity 1.0
    }
}

environment {
    XDG_CURRENT_DESKTOP asteroidz
    XDG_SESSION_TYPE wayland
    QT_AUTO_SCREEN_SCALE_FACTOR 1
    QT_WAYLAND_FORCE_DPI 1.8
    QT_FONT_DPI 168
    XCURSOR_SIZE 48
    XCURSOR_THEME Adwaita
    MESA_GLTHREAD "true"
}

spawn xrdb -load "~/.Xresources"

spawn-at-startup dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

spawn-at-startup wl-paste -pw wl-copy

spawn-at-startup vivaldi

spawn-at-startup dcal daemon

spawn-at-startup dms run --session

binds {
    Super+Ctrl+r { restart; }
    Super+Ctrl+l { retrain_monitor name:^DP-1$; }
    Super+Ctrl+Up { set_sdr_luminance +25; }
    Super+Ctrl+Down { set_sdr_luminance -25; }
    Super+Shift+p { pin; }
    Super+grave { togglespecialworkspace term; }
    Super+Shift+grave { movetospecialworkspace term; }
    Print { screenshot_ui region; }
    Shift+Print { screenshot_ui screen; }
    Super+Print { screenshot_ui window; }
}

mouse-binds {
    Super+btn_left { moveresize curmove; }
    NONE+btn_middle { togglemaximizescreen 0; }
    Super+btn_right { moveresize curresize; }
}

tag 1 { layout monocle; name web }

tag 2 { layout scroller }

tag 3 { layout tile }

tag 4 { layout tile }

tag 5 { layout tile }

tag 6 { layout tile }

tag 7 { layout tile }

tag 8 { layout tile }

tag 9 { layout tile }

window-rule { match app-id=^steam_app.*$; vrr_only_fullscreen 1 }

window-rule { match app-id=^gamescope$; vrr_only_fullscreen 1 }

source "./dms/colors.kdl"

source "./dms/layout.kdl"

source "./dms/cursor.kdl"

source "./dms/outputs.kdl"

source "./dms/windowrules.kdl"

source "./dms/binds.kdl"

source "./scenefx.kdl"
